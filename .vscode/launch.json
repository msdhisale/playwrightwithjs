{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Cucumber Tests",
      "program": "${workspaceFolder}/node_modules/.bin/cucumber-js",
      "args": [
        "--require",
        "support/**/*.js",
        "--require",
        "steps/**/*.js",
        "features/**/*.feature"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
