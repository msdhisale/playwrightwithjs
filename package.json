{
  "name": "playwrightwithjs",
  "version": "1.0.0",
  "description": "Cucumber BDD Framework with Page Object Model for TodoMVC",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:sanity": "cucumber-js --tags @sanity",
    "test:regression": "cucumber-js --tags @regression",
    "test:positive": "cucumber-js --tags @positive",
    "test:negative": "cucumber-js --tags @negative",
    "report": "node scripts/generatePdfReport.js"
  },
  "keywords": [
    "Cucumber",
    "BDD",
    "Playwright",
    "POM"
  ],
  "author": "QA Automation",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.0.10",
    "pdfkit": "^0.13.0",
    "playwright": "^1.58.0",
    "puppeteer": "^24.36.0"
  }
}
